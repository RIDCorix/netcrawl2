{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "API Server",
      "type": "shell",
      "command": "bash scripts/kill-port.sh 4800 && pnpm --filter server build && pnpm --filter server dev",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "showReuseMessage": false
      },
    },
    {
      "label": "Web UI",
      "dependsOn": [
        "API Server",
      ],
      "type": "shell",
      "command": "bash scripts/kill-port.sh 5173 && pnpm --filter ui dev",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "showReuseMessage": false
      },
    },
    {
      "label": "Code Server",
      "dependsOn": [
        "API Server",
      ],
      "type": "shell",
      "command": "pkill -9 -f 'uv run main.py' 2>/dev/null; sleep 1; cd workspace && uv run main.py",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "showReuseMessage": false
      },
    },
    {
      "label": "NetCrawl: Start All",
      "dependsOn": [
        "API Server",
        "Web UI",
        "Code Server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "showReuseMessage": false
      },
    },
    {
      "label": "NetCrawl: Kill All",
      "type": "shell",
      "command": "bash scripts/kill-port.sh 4800 && bash scripts/kill-port.sh 5173 && pkill -9 -f 'uv run main.py' 2>/dev/null; echo 'All killed'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "showReuseMessage": false
      },
    },
    {
      "label": "NetCrawl: Restart All",
      "dependsOn": [
        "NetCrawl: Kill All",
        "Web UI",
        "Code Server"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "echo": true,
        "focus": false,
        "showReuseMessage": false
      },
    }
  ]
}
